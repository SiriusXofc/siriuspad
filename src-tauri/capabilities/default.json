{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capability for SiriusPad",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:path:default",
    "dialog:default",
    "store:default",
    "fs:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "terminal-bash",
          "cmd": "bash",
          "args": true
        },
        {
          "name": "terminal-cmd",
          "cmd": "cmd.exe",
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "updater:default",
    "log:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered"
  ]
}
