{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SiriusPad",
  "version": "1.0.32",
  "identifier": "dev.siriusdev.siriuspad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SiriusPad",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "SiriusX",
    "homepage": "https://github.com/SiriusXofc/siriuspad",
    "license": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Bloco de notas local para desenvolvedores, com Markdown ao vivo, checklist, terminal e workspaces.",
    "longDescription": "SiriusPad e um scratchpad local-first para desenvolvedores. Ele combina edicao em Markdown com renderizacao ao vivo no proprio editor, checklist interativa, callouts, terminal embutido, historico por nota, workspaces e autosave. O foco e capturar bugs, comandos, snippets e ideias tecnicas com um fluxo rapido e direto, tanto no desktop quanto na beta mobile.",
    "targets": ["deb", "appimage", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "android": {
      "minSdkVersion": 24
    },
    "linux": {
      "appimage": {},
      "deb": {
        "depends": [],
        "section": "utils",
        "priority": "optional"
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/SiriusXofc/siriuspad/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRkNEQjhBNENERjMwMjIKUldRaU1OOU1pdHY4cjlpTDJETWt6NUtQbDJuM2d0a1pEL2ViK2ttZHhVWWVrcmxvcUh2QlAxRHgK"
    }
  }
}
