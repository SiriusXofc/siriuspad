{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SiriusPad",
  "version": "1.0.15",
  "identifier": "dev.siriusdev.siriuspad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SiriusPad",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/SiriusXofc/siriuspad/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRkNEQjhBNENERjMwMjIKUldRaU1OOU1pdHY4cjlpTDJETWt6NUtQbDJuM2d0a1pEL2ViK2ttZHhVWWVrcmxvcUh2QlAxRHgK"
    }
  }
}
